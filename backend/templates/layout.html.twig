<!DOCTYPE html>
<html lang="en"
    data-signals__ifmissing="{_darkMode: false, _currentView: '{{ defaults.view ?? 'graphs' }}', _settingsSection: 'preferences'}"
    data-persist="{_darkMode: $_darkMode, _currentView: $_currentView, _settingsSection: $_settingsSection, _graph_logscale: $_graph_logscale, _graph_stacked: $_graph_stacked, _graph_stepplot: $_graph_stepplot, _autoSyncGraph: $_autoSyncGraph}"
    {# Seed the dark-mode signal only when this browser has no saved toggle yet
       (first visit or after a cache wipe). The deployment default (NFSEN_DEFAULT_THEME
       / frontend.defaults.theme) decides the seed: 'auto' follows the OS setting,
       'dark'/'light' force it. An explicit user toggle persists to localStorage and
       always wins over this. See issue #156. #}
    data-init="localStorage.getItem('nfsen-persist:_darkMode') === null && ($_darkMode = {% if defaults.theme|default('auto') == 'dark' %}true{% elseif defaults.theme|default('auto') == 'light' %}false{% else %}window.matchMedia('(prefers-color-scheme: dark)').matches{% endif %})"
    data-attr:data-bs-theme="$_darkMode ? 'dark' : 'light'">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>nfsen-ng</title>

    {#
        php-via SSE bootstrap — mirrors the pattern in php-via's shell.html.
        contextId and basePath are auto-injected by Context::render().
        _connecting is a Datastar-managed indicator (no server signal needed).
        _disconnected is local-only (underscore prefix = never sent to server).
    #}
    <meta data-signals='{"via_ctx":"{{ contextId }}","_disconnected":false}'>
    <meta data-indicator="_connecting"
          data-on-interval__duration.15s.leading="!$_connecting && @get('{{ basePath }}_sse')"
          data-on:datastar-fetch="el === evt.detail.el &&
                             ((evt.detail.type.startsWith('datastar') && ($_disconnected = false)) ||
                             (['retrying', 'error', 'finished'].includes(evt.detail.type) && ($_disconnected = true)))">
    <meta data-init="window.addEventListener('beforeunload', () => { navigator.sendBeacon('{{ basePath }}_session/close', '{{ contextId }}'); });">
    <link rel="stylesheet" type="text/css" href="{{ basePath }}css/bootstrap.min.css">
    <link rel="stylesheet" type="text/css" href="{{ basePath }}css/nouislider.min.css?v={{ assetVersion }}">
    <link rel="stylesheet" type="text/css" href="{{ basePath }}css/nfsen-ng.css?v={{ assetVersion }}">
</head>

{#
    _currentView: purely browser-local navigation signal (underscore prefix).
    The server never reads it — in immediate mode every tab's content is always
    rendered and Datastar data-show handles visibility client-side. Persisted
    via data-persist (see html tag above) so a forced reload (e.g. after the
    SSE context's cleanup grace period expires while the tab is backgrounded)
    restores the tab the user was on instead of defaulting to Graphs.
#}
<body class="p-2">
    {# ── Reconnect banner ─────────────────────────────────────────────────── #}
    <div data-show="$_disconnected" style="display:none" class="alert alert-warning py-1 mb-1 text-center small">
        ⚠ Reconnecting to server…
    </div>

    {# ── Fatal config error ────────────────────────────────────────────────── #}
    {% if fatalError %}
    <div class="alert alert-danger">
        <strong>Fatal error:</strong> {{ fatalError }}
    </div>
    {% endif %}

    <header class="d-flex align-items-center gap-2">
        <a class="link-secondary flex-shrink-0" style="text-decoration: none;"
           href="https://github.com/mbolli/nfsen-ng" target="_blank">
            nfsen-ng <span id="version">{{ version }}</span>
        </a>
        {# Profile selector — only shown when multiple profiles are detected #}
        {% set availableProfilesList = available_profiles.getValue() %}
        {% if availableProfilesList|length > 1 %}
            <select class="form-select form-select-sm d-inline-block w-auto flex-shrink-0"
                    {{ bind(selected_profile) }}
                    data-on:change="@post('{{ changeProfile.url() }}')">
                {% set lastGroup = null %}
                {% for p in availableProfilesList %}
                    {% set parts = p|split('/') %}
                    {% if parts|length > 1 %}
                        {% set group = parts[0] %}
                        {% if group != lastGroup %}
                            {% if lastGroup is not null %}</optgroup>{% endif %}
                            <optgroup label="{{ group }}">
                            {% set lastGroup = group %}
                        {% endif %}
                        <option value="{{ p }}">{{ parts[1:parts|length]|join('/') }}</option>
                    {% else %}
                        {% if lastGroup is not null %}</optgroup>{% set lastGroup = null %}{% endif %}
                        <option value="{{ p }}">{{ p }}</option>
                    {% endif %}
                {% endfor %}
                {% if lastGroup is not null %}</optgroup>{% endif %}
            </select>
        {% endif %}
        {% include 'partials/nav.html.twig' %}
    </header>

    {# ── Global import status strip — visible on every tab while import runs ── #}
    <div id="importStatusStrip"
         data-show="${{ import_running.id() }}"
         style="display:none; cursor:pointer;"
         class="border-bottom mb-2"
         data-on:click="$_currentView = 'settings'; $_settingsSection = 'import'"
         title="Import in progress — click to view details">
        <div class="progress rounded-0" style="height:4px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated"
                 style="width: {{ importProgress }}%"></div>
        </div>
        <div class="d-flex justify-content-between align-items-center px-2 py-1">
            <small class="text-muted">
                {{ importStatusText ?: 'Importing\u2026' }}
                {% if importCurrentFile %}
                    &bull; <code class="small">{{ importCurrentFile|split('/')|last }}</code>
                {% endif %}
            </small>
            <small class="fw-semibold">
                {{ importProgress }}%{% if importEta %} &bull; {{ importEta }}{% endif %}
            </small>
        </div>
    </div>

    <main class="container-fluid tab-content">

        {# ── Server error signal (pushed by server, never sent back) ───────── #}
        <div class="alert alert-danger"
             data-effect="el.style.display = (${{ _error.id() }} != null && ${{ _error.id() }} != '') ? 'block' : 'none'"
             role="alert"
             data-text="${{ _error.id() }}"
             style="display: none;"></div>

        <div class="filter row align-items-start bg-body-tertiary border-bottom py-3 mb-3"
             style="flex-direction: row"
             data-show="$_currentView != 'settings'"
             data-indicator:nfcapd._counting
             data-on:change__window__throttle.1000ms="($_currentView === 'flows' || $_currentView === 'statistics' || $_currentView === 'sankey') && evt.target.closest('nfsen-daterange') && @post('{{ countFiles.url() }}')">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">

                        {% include 'partials/date-range.html.twig' %}

                        {# View-specific filter panels — all rendered, visibility via data-show #}
                        <div data-show="$_currentView == 'graphs'" class="col-12">
                            {% include 'partials/graph-filters.html.twig' %}
                        </div>
                        <div data-show="$_currentView == 'flows'" class="col-12" style="display: none;">
                            {% include 'partials/flow-filters.html.twig' %}
                        </div>
                        <div data-show="$_currentView == 'statistics'" class="col-12" style="display: none;">
                            {% include 'partials/stats-filters.html.twig' %}
                        </div>
                        <div data-show="$_currentView == 'sankey'" class="col-12" style="display: none;">
                            {% include 'partials/sankey-filters.html.twig' %}
                        </div>

                    </div>
                </div>
            </div>
        </div>

        {# ── View panels ───────────────────────────────────────────────────── #}
        <div data-show="$_currentView == 'graphs'" class="col-12">
            {% include 'partials/graph-view.html.twig' %}
        </div>
        <div data-show="$_currentView == 'flows'" class="col-12" style="display: none;">
            {% include 'partials/flow-view.html.twig' %}
        </div>
        <div data-show="$_currentView == 'statistics'" class="col-12" style="display: none;">
            {% include 'partials/stats-view.html.twig' %}
        </div>
        <div data-show="$_currentView == 'sankey'" class="col-12" style="display: none;">
            {% include 'partials/sankey-view.html.twig' %}
        </div>
        <div data-show="$_currentView == 'settings'" class="col-12" style="display: none;">
            {% include 'partials/settings.html.twig' %}
        </div>

    </main>

    {# ── Server stats footer ───────────────────────────────────────────────── #}
    <footer class="mt-4 pt-2 border-top text-center text-muted small">
        {# Traffic light: capture health (nfcapd proxy) + import daemon #}
        <span title="{{ captureLabel }}" style="cursor:help">
            <span class="text-{{ captureStatus }}">&#9679;</span> nfcapd
        </span>
        <span class="mx-1 text-muted opacity-50">|</span>
        <span title="{{ daemonLabel }}" style="cursor:help">
            <span class="text-{{ daemonStatus }}">&#9679;</span> daemon
        </span>
        &bull;
        <span class="badge bg-primary">{{ connections }} connection{{ connections != 1 ? 's' : '' }}</span>
        &bull;
        <a href="https://github.com/mbolli/nfsen-ng" target="_blank" rel="noopener" class="text-muted">nfsen-ng {{ version }}</a>
        &bull;
        <a href="https://github.com/mbolli/nfsen-ng/releases" target="_blank" rel="noopener" class="text-muted">Changelog</a>
        &bull;
        <a href="https://github.com/mbolli/nfsen-ng/issues" target="_blank" rel="noopener" class="text-muted">Issues</a>
    </footer>

    {# ── JS ────────────────────────────────────────────────────────────────── #}
    <script src="{{ basePath }}js/nouislider.min.js" defer></script>
    <script src="{{ basePath }}js/echarts.min.js" defer></script>

    {#
        Import map so datastar-persist.js's `import ... from 'datastar'` resolves
        to the exact same module instance as the main datastar.js script tag
        below. A relative import (`../datastar.js`) would resolve to a URL
        without the `?v=` cache-busting query string, which the module loader
        treats as a DIFFERENT module — loading the whole engine a second time
        with its own MutationObserver, signal store, etc. Mirrors
        mbolli/datastar-attribute-prop's own approach.

        MUST be the first `type="module"`-adjacent tag in the document — including
        before inline `<script type="module">` blocks, not just external ones.
        Per the import maps spec, an import map is only honoured if no module
        script has been "prepared" yet, and that step runs the moment the parser
        reaches ANY module script's tag (inline scripts included — no fetch
        needed, so it happens immediately), not when it executes. Putting this
        after any earlier `type="module"` tag silently disables the whole import
        map — the bare `from 'datastar'` specifier in datastar-persist.js then
        fails to resolve, so that module (and every signal it was supposed to
        persist) never loads, in every browser, regardless of cache state. The
        two `defer` classic scripts above are fine to precede it: only module
        scripts and modulepreload links trigger the restriction.
    #}
    <script type="importmap">{"imports": {"datastar": "{{ basePath }}js/datastar.js?v={{ assetVersion }}"}}</script>

    <script type="module">
        /**
         * Returns true only when a filter-change event originated from inside
         * the graph filters panel or the date range controls. Prevents spurious
         * graph refreshes when the user changes flow / stats filters.
         */
        window.mayUpdateGraph = (function() {
            let dateRangeNode = null;
            let dateRangeControlsNode = null;
            return function(evt, el) {
                const target = evt.target;
                if (el && el.contains(target)) return true;
                if (!dateRangeNode) dateRangeNode = document.querySelector('nfsen-daterange');
                if (dateRangeNode && dateRangeNode.contains(target)) return true;
                if (!dateRangeControlsNode) dateRangeControlsNode = document.querySelector('.date-range-controls');
                if (dateRangeControlsNode && dateRangeControlsNode.contains(target)) return true;
                return false;
            };
        })();
    </script>

    <script type="module">
        import { tzOptions } from '{{ basePath }}js/components/tz-utils.js?v={{ assetVersion }}';
        window.tzOptions = tzOptions;
    </script>

    {#
        alert-template-preview.js defines window.* helpers read by data-effect
        attributes in alerts-settings.html.twig, which Datastar evaluates eagerly
        during its initial DOM walk below -- it must load and run BEFORE
        datastar.js, unlike the other components/* scripts here (which only need
        to exist by the time a user later clicks something, not at parse time).
        Execution order for external module scripts follows document order
        regardless of the import map's position, so this still runs before
        datastar.js below.
    #}
    <script type="module" src="{{ basePath }}js/components/alert-template-preview.js?v={{ assetVersion }}"></script>
    <script type="module" src="{{ basePath }}js/datastar.js?v={{ assetVersion }}"></script>
    <script type="module" src="{{ basePath }}js/components/datastar-persist.js?v={{ assetVersion }}"></script>
    <script type="module" src="{{ basePath }}js/components/nfsen-chart.js?v={{ assetVersion }}"></script>
    <script type="module" src="{{ basePath }}js/components/nfsen-sankey.js?v={{ assetVersion }}"></script>
    <script type="module" src="{{ basePath }}js/components/nfsen-table.js?v={{ assetVersion }}"></script>
    <script type="module" src="{{ basePath }}js/components/nfsen-daterange.js?v={{ assetVersion }}"></script>
    <script type="module" src="{{ basePath }}js/components/nfsen-toast.js?v={{ assetVersion }}"></script>
    {# Tooltip popup container — data-ignore-morph prevents Datastar SSE from removing JS-appended tooltips #}
    <div id="nfsen-tip-container" data-ignore-morph></div>
    {# Placeholder for the server-rendered IP info modal fragment #}
    <div id="ip-modal-placeholder"></div>

    <script type="module" src="{{ basePath }}js/components/nfsen-filter-manager.js?v={{ assetVersion }}"></script>
    <script type="module" src="{{ basePath }}js/components/nfsen-tooltip.js?v={{ assetVersion }}"></script>

    {# ── Alert-fired toast container ──────────────────────────────────────── #}
    {# Fixed overlay (bottom-right). New toasts injected here when alerts fire  #}
    {# or via window.showMessage(). data-ignore-morph keeps JS-appended toasts. #}
    <div id="alerts-toast-container" data-ignore-morph>{{ alertFiredHtml|raw }}</div>

    <script>window.withViewTransition = fn => document.startViewTransition ? document.startViewTransition(fn) : fn();</script>

</body>
</html>
