{#
    Date range slider + quick-select buttons.
    datestart / dateend are server-registered signals; bind() emits the correct
    context-scoped data-bind attribute so Datastar sends them back on actions.

    dataRangeMin / dataRangeMax are server-owned signals updated from actual RRD
    first/last timestamps so the slider is bounded to real data instead of a
    fixed importYears window.
#}
{% set fromMs    = ("now - 1 day"|date('U')) ~ '000' %}
{% set nowMs     = "now"|date('U') ~ '000' %}

<div class="mb-3">
    <nfsen-daterange
        id="dateRangeSlider"
        data-ignore-morph
        data-min="{{ dataRangeMin.int() * 1000 }}"
        data-max="{{ dataRangeMax.int() * 1000 }}"
        data-from="{{ fromMs }}"
        data-to="{{ nowMs }}"
        data-ref="_daterangeWidget"
        data-on:range-change="${{ datestart.id() }} = Math.floor(evt.detail.from / 1000); ${{ dateend.id() }} = Math.floor(evt.detail.to / 1000); el.dispatchEvent(new Event('change', { bubbles: true }));">
    </nfsen-daterange>
</div>

<div class="d-flex justify-content-end gap-2 flex-wrap mb-4 date-range-controls"
     data-signals='{"_activeDuration": 86400000}'>

    {# Quick-select preset windows #}
    <div class="btn-group" id="date_slot" role="group">
        {% for label, ms in {
            '1 hour':  3600000,
            '24 hours': 86400000,
            'Week':    604800000,
            'Month':   2592000000,
            'Year':    31536000000
        } %}
        <button type="button"
                class="btn btn-outline-primary"
                data-class:active="$_activeDuration === {{ ms }}"
                data-on:click="document.getElementById('dateRangeSlider').setQuickRange({{ ms }}); $_activeDuration = {{ ms }};">
            {{ label }}
        </button>
        {% endfor %}
    </div>

    {# Previous / next / jump-to-now #}
    <div class="btn-group" id="date_slot_nav" role="group">
        <button type="button" class="btn btn-outline-primary"
                data-on:click="document.getElementById('dateRangeSlider').navigate('prev'); $_activeDuration = 0;"
                title="Previous period">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
            </svg>
        </button>
        <button type="button" class="btn btn-outline-primary"
                data-on:click="document.getElementById('dateRangeSlider').navigate('next'); $_activeDuration = 0;"
                title="Next period">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-right" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8"/>
            </svg>
        </button>
        <button type="button" class="btn btn-outline-primary"
                data-on:click="document.getElementById('dateRangeSlider').goToEnd(); $_activeDuration = 0;"
                title="Jump to now (most recent data)">
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="bi bi-arrow-bar-right" viewBox="0 0 16 16" width="16"><path d="M3 8a.5.5 0 0 1 .5-.5h5.793L7.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 1 1-.708-.708L9.293 8.5H3.5A.5.5 0 0 1 3 8" style="transform-box:fill-box" transform-origin="50% 50%"/><path d="M13.501 1a.5.5 0 0 0-.5.5v13a.5.5 0 0 0 1 0v-13a.5.5 0 0 0-.5-.5" style="transform-box:fill-box" transform="rotate(180 0 0)" transform-origin="50% 50%"/></svg>
        </button>
    </div>

    {# Copy graph zoom range back to the date slider (graphs view only) #}
    <div class="btn-group" id="date_syncing" role="group">
        <nfsen-tooltip data-ignore-morph text="Sync date range slider with current graph zoom/pan level" placement="bottom" no-icon>
            <button type="button"
                    class="btn btn-outline-primary sync-date"
                    disabled
                    data-on:click="const range = $_graphWidget.getCurrentRange(); $_daterangeWidget.updateRange(range.from, range.to); el.disabled = true;"
                    data-show="$_currentView == 'graphs'">
                Copy from graph
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-repeat" viewBox="0 0 16 16">
                    <path d="M11.534 7h3.932a.25.25 0 0 1 .192.41l-1.966 2.36a.25.25 0 0 1-.384 0l-1.966-2.36a.25.25 0 0 1 .192-.41m-11 2h3.932a.25.25 0 0 0 .192-.41L2.692 6.23a.25.25 0 0 0-.384 0L.342 8.59A.25.25 0 0 0 .534 9"/>
                    <path fill-rule="evenodd" d="M8 3c-1.552 0-2.94.707-3.857 1.818a.5.5 0 1 1-.771-.636A6.002 6.002 0 0 1 13.917 7H12.9A5 5 0 0 0 8 3M3.1 9a5.002 5.002 0 0 0 8.757 2.182.5.5 0 1 1 .771.636A6.002 6.002 0 0 1 2.083 9z"/>
                </svg>
            </button>
        </nfsen-tooltip>
    </div>

</div>
