{#
    Flow query filter controls.

    flowAggregation is initialised server-side with the full nested structure so
    sub-property bindings like {{ bind(flowAggregation) }}.bidirectional work.
    The server never reads flows_outputFormat (hardcoded to JSON); it is kept as a
    client-local signal initialised here so the UI state is preserved across re-renders.
#}
<div class="row g-3">

    {# Limit #}
    <div id="filterFlowsLimit" class="col-2">
        <div class="filter-group">
        <p class="filter-label">Limit Flows
            <nfsen-tooltip data-ignore-morph text="Maximum number of flow records to display (-c option)." placement="top"></nfsen-tooltip>
        </p>
        {% set _flowLimit = flows_limit.int() %}
        <select class="form-control form-select" {{ bind(flows_limit) }}>
            {% for n in [20, 50, 100, 500, 1000, 10000] %}
            <option value="{{ n }}"{{ _flowLimit == n ? ' selected' : '' }}>{{ n }}</option>
            {% endfor %}
        </select>
        </div>
    </div>

    {# Sources #}
    <div id="filterFlowSources" class="col-2">
        <div class="filter-group">
        <p class="filter-label">Sources
            <nfsen-tooltip data-ignore-morph text="NetFlow sources to query. Multiple sources merged with -M." placement="top"></nfsen-tooltip>
        </p>
        <select {{ bind(graph_sources) }} multiple class="form-control form-select">
            <option value="any">Any</option>
            {% for source in sources %}
            <option value="{{ source }}" selected>{{ source }}</option>
            {% endfor %}
        </select>
        </div>
    </div>

    {# NFDUMP filter #}
    <div class="col">
        <div class="filter-group">
        <p class="filter-label">NFDUMP filter
            <nfsen-tooltip data-ignore-morph text="Filter syntax similar to tcpdump/pcap. Example: dst port 80" placement="right"></nfsen-tooltip>
        </p>
        <textarea class="form-control" id="filterNfdumpTextarea"
                  {{ bind(flows_filter) }} rows="3" autocomplete="on"></textarea>
        <nfsen-filter-manager
            data-ignore-morph
            data-target-textarea="filterNfdumpTextarea"
            data-default-filters="{{ filters|json_encode }}">
        </nfsen-filter-manager>
        </div>
    </div>

    {# Byte thresholds — prepended to the nfdump filter expression #}
    <div class="col-auto">
        <div class="filter-group">
        <p class="filter-label">Min bytes
            <nfsen-tooltip data-ignore-morph text="Only show flows with at least this many bytes. Prepended as 'bytes &gt; value'. Accepts SI suffixes: k, M, G." placement="top"></nfsen-tooltip>
        </p>
        <input type="text" {{ bind(flows_lower_limit) }} class="form-control" style="width:7rem" placeholder="e.g. 1M">
        </div>
    </div>
    <div class="col-auto">
        <div class="filter-group">
        <p class="filter-label">Max bytes
            <nfsen-tooltip data-ignore-morph text="Only show flows with at most this many bytes. Prepended as 'bytes &lt; value'. Accepts SI suffixes: k, M, G." placement="top"></nfsen-tooltip>
        </p>
        <input type="text" {{ bind(flows_upper_limit) }} class="form-control" style="width:7rem" placeholder="e.g. 100M">
        </div>
    </div>

    {# Aggregation & output #}
    <div id="filterFlowAggregation" class="col-12 col-xl">
        <div class="filter-group">
        <p class="filter-label mb-2">Aggregation &amp; Output
            <nfsen-tooltip data-ignore-morph text="Aggregate flows: Bi-directional (-b), Protocol, Port, IP/prefix, or sort by tstart." placement="top"></nfsen-tooltip>
        </p>
        <div class="row g-2">

            {# Global & port aggregation #}
            <div class="col">
                <label class="filter-sublabel">Global</label>
                <div class="btn-group btn-group-sm d-flex mb-2" id="filterFlowAggregationGlobal">
                    <input type="checkbox" class="btn-check" name="bidirectional"
                           id="filterFlowAggBi" {{ bind(flows_agg_bidirectional) }}>
                    <label class="btn btn-outline-primary" for="filterFlowAggBi">Bi-directional</label>
                    <input type="checkbox" class="btn-check" name="proto"
                           id="filterFlowAggProto" {{ bind(flows_agg_proto) }}>
                    <label class="btn btn-outline-primary" for="filterFlowAggProto">Protocol</label>
                </div>
                <label class="filter-sublabel">Port</label>
                <div class="btn-group btn-group-sm d-flex" id="filterFlowAggregationPort">
                    <input type="checkbox" class="btn-check" name="srcport"
                           id="filterFlowAggPortSrc" {{ bind(flows_agg_srcport) }}>
                    <label class="btn btn-outline-primary" for="filterFlowAggPortSrc">Source</label>
                    <input type="checkbox" class="btn-check" name="dstport"
                           id="filterFlowAggPortDst" {{ bind(flows_agg_dstport) }}>
                    <label class="btn btn-outline-primary" for="filterFlowAggPortDst">Destination</label>
                </div>
            </div>

            {# IP aggregation #}
            <div class="col">
                <label class="filter-sublabel">IP Aggregation</label>
                <div class="row g-1">
                    <div class="col-6">
                        <select data-attr:disabled="${{ flows_agg_bidirectional.id() }}"
                                class="form-select form-select-sm"
                                {{ bind(flows_agg_srcip) }}>
                            <option value="none">Src: None</option>
                            <option value="srcip">Src: IP</option>
                            <option value="srcip4">Src: IPv4 /</option>
                            <option value="srcip6">Src: IPv6 /</option>
                        </select>
                        <input data-attr:disabled="${{ flows_agg_srcip.id() }} == 'srcip' || ${{ flows_agg_srcip.id() }} == 'none'"
                               placeholder="24" type="text"
                               class="form-control form-control-sm mt-1" style="width:3.5rem"
                               {{ bind(flows_agg_srcip_prefix) }}>
                    </div>
                    <div class="col-6">
                        <select data-attr:disabled="${{ flows_agg_bidirectional.id() }}"
                                class="form-select form-select-sm"
                                {{ bind(flows_agg_dstip) }}>
                            <option value="none">Dst: None</option>
                            <option value="dstip">Dst: IP</option>
                            <option value="dstip4">Dst: IPv4 /</option>
                            <option value="dstip6">Dst: IPv6 /</option>
                        </select>
                        <input data-attr:disabled="${{ flows_agg_dstip.id() }} == 'dstip' || ${{ flows_agg_dstip.id() }} == 'none'"
                               placeholder="24" type="text"
                               class="form-control form-control-sm mt-1" style="width:3.5rem"
                               {{ bind(flows_agg_dstip_prefix) }}>
                    </div>
                </div>
            </div>

            {# Output options #}
            <div class="col" id="filterOutput">
                <label class="filter-sublabel">Options</label>
                <div id="flowsFilterOther">
                    <input type="checkbox" class="btn-check" name="ordertstart"
                           id="flowsFilterOrderTstart" {{ bind(flows_orderByTstart) }}>
                    <label class="btn btn-outline-primary btn-sm" for="flowsFilterOrderTstart">Order by tstart</label>
                </div>
            </div>

        </div>
        </div>
    </div>

    {# Submit #}
    <div class="col-12 border-top mt-3 pt-3">
        <nfsen-tooltip data-ignore-morph text="Execute nfdump query with current filters" placement="top" no-icon>
            <button type="button"
                    class="btn btn-primary"
                    data-indicator:flows._indicator
                    data-class:loading="$flows._indicator"
                    data-on:click="$_flows_queried = true; @post('{{ flowActions.url() }}')">
                <span data-show="!$flows._indicator">Process data</span>
                <span class="spinner-grow spinner-grow-sm" data-show="$flows._indicator" role="status" aria-hidden="true"></span>
                <span data-show="$flows._indicator">Processing…</span>
            </button>
        </nfsen-tooltip>
        <button type="button"
                class="btn btn-outline-danger btn-sm ms-1"
                style="display:none"
                data-show="$flows._indicator"
                data-on:click="@post('{{ killNfdump.url() }}')">Kill</button>
    </div>

</div>
