{#
    Flow results panel.
    flowMessageHtml and flowTableHtml are pre-rendered server-side on every sync.
    The server pushes them as part of the full-page DOM morph — no targeted element
    patches needed.
#}
<div class="row" data-signals__ifmissing='{"_flows_queried": false}'>
    <div class="col-12">
        {# Empty state — shown until the user submits the first query #}
        <div data-show="!$_flows_queried" class="text-center py-5 text-muted">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" class="bi bi-funnel mb-3 opacity-25" viewBox="0 0 16 16">
                <path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5zm1 .5v1.308l4.372 4.858A.5.5 0 0 1 7 8.5v5.306l2-.666V8.5a.5.5 0 0 1 .128-.334L13.5 3.308V2z"/>
            </svg>
            <p class="mb-1 fw-semibold">No results yet</p>
            <p class="small">Configure filters above and click <strong>Process data</strong> to query flows.</p>
        </div>
        {# Results card — shown after the first query #}
        <div data-show="$_flows_queried">
        <div class="card" data-class:loading="$flows._indicator">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title mb-0">Network Flows</h5>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-info" data-text="${{ flowCount.id() }}"></span>
                        <span class="text-muted small">flows</span>
                    </div>
                </div>
                <div id="flowMessage">{{ flowMessageHtml|raw }}</div>
                <div id="flowTable">{{ flowTableHtml|raw }}</div>
            </div>
        </div>
        </div>
    </div>
</div>
