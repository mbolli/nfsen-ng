{#
    IP info modal fragment — pushed by the server as a Datastar patchElements event.
    Replaces #ip-modal-placeholder in the DOM, then JS calls .showModal() on #ip-modal-inner.
    Uses a native <dialog> element — no Bootstrap JS / Popper required.
#}
<div id="ip-modal-placeholder">
    <dialog id="ip-modal-inner" aria-labelledby="ipModalLabel">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="ipModalLabel">Info for IP: {{ ip }}</h1>
                <button type="button" class="btn-close" aria-label="Close"
                        data-on:click="document.getElementById('ip-modal-inner').close()"></button>
            </div>
            <div class="modal-body">
                <dl class="row mb-3">
                    <dt class="col-sm-3">Hostname</dt>
                    <dd class="col-sm-9{% if hostname == 'could not be resolved' %} text-secondary fst-italic{% endif %}">{{ hostname }}</dd>
                </dl>

                {% if netboxData is defined and netboxData is not empty %}
                    <h3 class="fs-6 fw-semibold text-muted mb-1">Netbox</h3>
                    <table class="table table-sm table-bordered mb-3">
                        {% if netboxData.address is defined %}
                            <tr><th class="col-4">Address</th><td>{{ netboxData.address }}</td></tr>
                        {% endif %}
                        {% if netboxData.description is defined and netboxData.description %}
                            <tr><th>Description</th><td>{{ netboxData.description }}</td></tr>
                        {% endif %}
                        {% if netboxData.tenant is defined and netboxData.tenant %}
                            <tr><th>Tenant</th><td>{{ netboxData.tenant.name }}</td></tr>
                        {% endif %}
                        {% if netboxData.vrf is defined and netboxData.vrf %}
                            <tr><th>VRF</th><td>{{ netboxData.vrf.name }}</td></tr>
                        {% endif %}
                        {% if netboxData.status is defined %}
                            <tr><th>Status</th><td>{{ netboxData.status.label ?? netboxData.status }}</td></tr>
                        {% endif %}
                        {% if netboxData.role is defined and netboxData.role %}
                            <tr><th>Role</th><td>{{ netboxData.role.label ?? netboxData.role }}</td></tr>
                        {% endif %}
                    </table>
                {% endif %}

                {% if geoData.error is defined and geoData.error %}
                    <div class="alert alert-warning">{{ geoData.reason ?? 'IP lookup failed' }}</div>
                {% else %}
                    {% set countryCode = geoData.country_code ?? '' %}
                    <h3>
                        {{ ip }}
                        {% if countryCode %}
                            <img src="https://flagcdn.com/w40/{{ countryCode|lower }}.png"
                                 alt="{{ geoData.country_name ?? '' }}"
                                 title="{{ geoData.country_name ?? '' }}"
                                 style="width: 3rem" />
                        {% endif %}
                    </h3>
                    {% set ignored = ['country_code', 'country_code_iso3', 'country_tld', 'country_area',
                                      'country_population', 'continent_code', 'in_eu', 'network', 'version',
                                      'error', 'reason'] %}
                    <table class="table table-striped table-hover table-sm">
                        {% for key, value in geoData %}
                            {% if key not in ignored %}
                                <tr><th>{{ key }}</th><td>{{ value }}</td></tr>
                            {% endif %}
                        {% endfor %}
                    </table>
                {% endif %}
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary"
                        data-on:click="document.getElementById('ip-modal-inner').close()">Close</button>
            </div>
        </div>
    </dialog>
</div>
