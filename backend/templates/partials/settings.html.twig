{#
    User preferences panel — editable in the browser, persisted to preferences.json.

    Fields here are "user-owned" defaults. Deployment config (sources, ports,
    nfdump paths, datasource, import_years) stays in env vars / settings.php and
    is shown as read-only for reference.
#}

<div class="row justify-content-center mt-4">
<div class="col-lg-8">

{# ── Save feedback toast ─────────────────────────────────────────────────── #}
{# Error messages from server (success is shown client-side immediately on click) #}
<div id="settings-toast-container" data-ignore-morph>{{ settingsMessageHtml|raw }}</div>

{# ── User Preferences ────────────────────────────────────────────────────── #}
<div class="card mb-4">
    <div class="card-header fw-semibold">User Preferences</div>
    <div class="card-body">
        <p class="text-muted small mb-3">
            These settings are saved to <code>preferences.json</code> and applied on top of
            your deployment configuration. They take effect immediately across all open tabs.
        </p>

        <div class="row g-3">

            {# Default view #}
            <div class="col-md-4">
                <label class="form-label fw-semibold small">Default view</label>
                {% set _v = settings_defaultView.string() %}
                <select class="form-select form-select-sm" {{ bind(settings_defaultView) }}>
                    <option value="graphs" {{ _v == 'graphs' ? 'selected' : '' }}>Graphs</option>
                    <option value="flows" {{ _v == 'flows' ? 'selected' : '' }}>Flows</option>
                    <option value="statistics" {{ _v == 'statistics' ? 'selected' : '' }}>Statistics</option>
                </select>
            </div>

            {# Default log level #}
            <div class="col-md-4">
                <label class="form-label fw-semibold small">Log level</label>
                {% set _v = settings_logPriority.string() %}
                <select class="form-select form-select-sm" {{ bind(settings_logPriority) }}>
                    <option value="debug" {{ _v == 'debug' ? 'selected' : '' }}>Debug</option>
                    <option value="info" {{ _v == 'info' ? 'selected' : '' }}>Info</option>
                    <option value="notice" {{ _v == 'notice' ? 'selected' : '' }}>Notice</option>
                    <option value="warning" {{ _v == 'warning' ? 'selected' : '' }}>Warning</option>
                    <option value="error" {{ _v == 'error' ? 'selected' : '' }}>Error</option>
                </select>
            </div>

        </div>{# /row #}

        <hr class="my-3">
        <h6 class="text-muted small text-uppercase mb-3">Graph defaults</h6>

        <div class="row g-3">

            {# Default graph display #}
            <div class="col-md-4">
                <label class="form-label fw-semibold small">Display</label>
                {% set _v = settings_graphDisplay.string() %}
                <select class="form-select form-select-sm" {{ bind(settings_graphDisplay) }}>
                    <option value="sources" {{ _v == 'sources' ? 'selected' : '' }}>Sources</option>
                    <option value="ports" {{ _v == 'ports' ? 'selected' : '' }}>Ports</option>
                    <option value="protocols" {{ _v == 'protocols' ? 'selected' : '' }}>Protocols</option>
                </select>
            </div>

            {# Default graph datatype #}
            <div class="col-md-4">
                <label class="form-label fw-semibold small">Datatype</label>
                {% set _v = settings_graphDatatype.string() %}
                <select class="form-select form-select-sm" {{ bind(settings_graphDatatype) }}>
                    <option value="traffic" {{ _v == 'traffic' ? 'selected' : '' }}>Traffic (bits/s)</option>
                    <option value="packets" {{ _v == 'packets' ? 'selected' : '' }}>Packets/s</option>
                    <option value="bytes" {{ _v == 'bytes' ? 'selected' : '' }}>Bytes</option>
                    <option value="flows" {{ _v == 'flows' ? 'selected' : '' }}>Flows</option>
                </select>
            </div>

            {# Default graph protocols #}
            <div class="col-md-4">
                <label class="form-label fw-semibold small">Protocols</label>
                {% set _protos = settings_graphProtocols.array() %}
                <select class="form-select form-select-sm" {{ bind(settings_graphProtocols) }} multiple>
                    <option value="any" {{ 'any' in _protos ? 'selected' : '' }}>Any</option>
                    <option value="tcp" {{ 'tcp' in _protos ? 'selected' : '' }}>TCP</option>
                    <option value="udp" {{ 'udp' in _protos ? 'selected' : '' }}>UDP</option>
                    <option value="icmp" {{ 'icmp' in _protos ? 'selected' : '' }}>ICMP</option>
                    <option value="other" {{ 'other' in _protos ? 'selected' : '' }}>Other</option>
                </select>
                <div class="form-text">Hold Ctrl/⌘ to select multiple.</div>
            </div>

        </div>{# /row #}

        <hr class="my-3">
        <h6 class="text-muted small text-uppercase mb-3">Flow &amp; statistics defaults</h6>

        <div class="row g-3">

            {# Default flow limit #}
            <div class="col-md-4">
                <label class="form-label fw-semibold small">Flow limit</label>
                {% set _v = settings_flowLimit.int() %}
                <select class="form-select form-select-sm" {{ bind(settings_flowLimit) }}>
                    {% for n in [20, 50, 100, 500, 1000, 10000] %}
                    <option value="{{ n }}" {{ _v == n ? 'selected' : '' }}>{{ n }}</option>
                    {% endfor %}
                </select>
            </div>

            {# Default stats order-by #}
            <div class="col-md-4">
                <label class="form-label fw-semibold small">Statistics order by</label>
                {% set _v = settings_statsOrderBy.string() %}
                <select class="form-select form-select-sm" {{ bind(settings_statsOrderBy) }}>
                    <option value="bytes" {{ _v == 'bytes' ? 'selected' : '' }}>Bytes</option>
                    <option value="packets" {{ _v == 'packets' ? 'selected' : '' }}>Packets</option>
                    <option value="flows" {{ _v == 'flows' ? 'selected' : '' }}>Flows</option>
                    <option value="pps" {{ _v == 'pps' ? 'selected' : '' }}>Packets/s</option>
                    <option value="bps" {{ _v == 'bps' ? 'selected' : '' }}>Bits/s</option>
                    <option value="bpp" {{ _v == 'bpp' ? 'selected' : '' }}>Bytes/packet</option>
                </select>
            </div>

        </div>{# /row #}

        <hr class="my-3">
        <h6 class="text-muted small text-uppercase mb-3">Filter presets</h6>

        <div class="row g-3">
            <div class="col-12">
                <label class="form-label fw-semibold small">
                    nfdump filter presets
                    <span class="text-muted fw-normal">(one per line — available as quick-select in the Flows and Statistics tabs)</span>
                </label>
                <textarea id="settings-filters-textarea"
                          class="form-control form-control-sm font-monospace"
                          {{ bind(settings_filtersText) }}
                          rows="5"
                          placeholder="proto tcp&#10;dst port 443&#10;host 192.168.1.1"></textarea>
            </div>
        </div>{# /row #}

        <div class="d-flex justify-content-end mt-3">
            <button class="btn btn-primary btn-sm"
                    data-indicator:_settings_saving
                    data-on:click="document.dispatchEvent(new CustomEvent('nfsen-global-filters-updated',{detail:{filters:(document.getElementById('settings-filters-textarea')?.value||'').split('\n').map(s=>s.trim()).filter(s=>s)}})); window.showMessage('success', 'Preferences saved.', true, '#settings-toast-container'); @post('{{ saveSettings.url() }}')">
                <span data-show="$_settings_saving" style="display:none;"
                      class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                Save preferences
            </button>
        </div>

    </div>{# /card-body #}
</div>{# /card #}

{# ── Alert Rules ─────────────────────────────────────────────────────────── #}
{% include 'partials/alerts-settings.html.twig' %}

{# ── Deployment configuration (read-only) ───────────────────────────────── #}
<div class="card mb-4">
    <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
        Deployment configuration
        <span class="badge bg-secondary fw-normal">read-only</span>
    </div>
    <div class="card-body">
        <p class="text-muted small mb-3">
            These values come from environment variables or <code>settings.php</code>.
            Restart the container to apply changes.
        </p>
        <table class="table table-sm table-borderless small mb-0">
            <tbody>
                <tr>
                    <td class="text-muted" style="width:40%">Sources</td>
                    <td><code>{{ sources|join(', ') ?: '(none configured)' }}</code></td>
                </tr>
                <tr>
                    <td class="text-muted">Ports</td>
                    <td><code>{{ ports|join(', ') ?: '(none configured)' }}</code></td>
                </tr>
                <tr>
                    <td class="text-muted">Datasource</td>
                    <td><code>{{ deployDatasource }}</code></td>
                </tr>
                <tr>
                    <td class="text-muted">Import years</td>
                    <td><code>{{ deployImportYears }}</code></td>
                </tr>
                <tr>
                    <td class="text-muted">nfdump binary</td>
                    <td><code>{{ deployNfdumpBinary }}</code></td>
                </tr>
                <tr>
                    <td class="text-muted">Profiles data path</td>
                    <td><code>{{ deployNfdumpProfiles }}</code></td>
                </tr>
                <tr>
                    <td class="text-muted">Preferences file</td>
                    <td><code>{{ deployPrefsFile }}</code></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

</div>{# /col #}
</div>{# /row #}
