{#
    Statistics results panel.
#}
<div class="row mb-4" data-signals__ifmissing='{"_stats_queried": false}'>
    <div class="col-12">
        {# Empty state — shown until the user submits the first query #}
        <div data-show="!$_stats_queried" class="text-center py-5 text-muted">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" class="bi bi-bar-chart mb-3 opacity-25" viewBox="0 0 16 16">
                <path d="M4 11H2v3h2zm5-4H7v7h2zm5-5v12h-2V2zm-2-1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1zM6 7a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1zm-5 4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1z"/>
            </svg>
            <p class="mb-1 fw-semibold">No results yet</p>
            <p class="small">Configure filters above and click <strong>Process data</strong> to generate statistics.</p>
        </div>
        {# Results card — shown after the first query #}
        <div data-show="$_stats_queried">
        <div class="card" data-class:loading="$stats._indicator">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title mb-0">Output</h5>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-info" data-text="${{ statsCount.id() }}"></span>
                        <span class="text-muted small">rows</span>
                    </div>
                </div>
                <div id="statsMessage">
                    {% for n in statsNotifications %}
                    <div class="alert alert-{{ n.type == 'error' ? 'danger' : n.type }} alert-dismissible fade show" role="alert">
                        {{ n.message|raw }}
                        <button type="button" class="btn-close" data-on:click="@post('{{ action_dismissNotification }}?id={{ n.id }}')" aria-label="Close"></button>
                    </div>
                    {% endfor %}
                </div>
                <div id="statsTable">{{ statsTableHtml|raw }}</div>
            </div>
        </div>
        </div>
    </div>
</div>
