{
    "name": "mbolli/nfsen-ng",
    "version": "1.0.0-alpha",
    "description": "Responsive NetFlow visualizer built on top of nfdump tools",
    "license": "Apache-2.0",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "ext-inotify": "*",
        "ext-openswoole": "*",
        "ext-rrd": "*",
        "mbolli/php-via": "dev-master"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "3.x",
        "jetbrains/phpstorm-attributes": "^1.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "mbolli\\nfsen_ng\\": "backend/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "before-commit": [
            "@fix",
            "@test-phpstan"
        ],
        "lint": "@fix --dry-run",
        "lint-diff": "@fix --dry-run --diff",
        "fix": "php-cs-fixer fix --ansi --allow-risky=yes -v --config=./.php-cs-fixer.php",
        "test-phpstan": "phpstan analyse backend -l 5 -a backend/settings/settings.php",
        "test": "pest",
        "test-coverage": "pest --coverage"
    },
    "authors": [
        {
            "name": "Michael Bolli",
            "email": "michael@bolli.us"
        }
    ],
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
